  "db_name": "PostgreSQL",
  "query": "SELECT\n            t.type_name,\n            t.type_name_k,\n            t.type_name_r,\n            t.type_name_zh,\n            t.type_name_ko,\n            t.color,\n            t.kind AS \"kind?\",\n            t.direction AS \"direction?\",\n            sst.*,\n            s.line_cd\n            FROM types as t\n            JOIN station_station_types AS sst ON sst.line_group_cd IN (SELECT(UNNEST($1::integer[])))\n            JOIN stations AS s ON s.station_cd = sst.station_cd\n            WHERE \n                t.type_cd = sst.type_cd",
